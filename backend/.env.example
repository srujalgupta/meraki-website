NODE_ENV=development
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/meraki?retryWrites=true&w=majority
PORT=5000
CLIENT_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://your-site.vercel.app,https://*.vercel.app
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
GOOGLE_PLACES_LANGUAGE_CODE=en
# Leave MONGO_URI empty to run the API in read-only sample-data mode.
# Set GOOGLE_PLACES_API_KEY and GOOGLE_PLACES_PLACE_ID to show live Google reviews and reviewer photos.
# CLIENT_ORIGINS supports exact origins and simple wildcards like https://*.vercel.app.
# Set CLIENT_ORIGINS=* only when you intentionally want to allow requests from any origin.
